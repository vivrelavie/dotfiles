{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "~/.config/fastfetch/logos/cat.txt",
        "padding": {
            "top": 1,
            "left": 2,
            "right": 2
        },
        "color": {"1": "{{colors.primary.default.hex}}"}
    },
    "display": {
        "separator": "  "
    },
    "modules": [
        "break",
        {
          "type": "title",
          "key": "",
          "keyColor": "{{colors.primary.default.hex}}"
        },
        {
          "type": "disk",
          "key": "󱦟 OS Age",
          "folders": "/",
          "keyColor": "{{colors.primary.default.hex}}",
          "format": "{days} days"
        },
        "break",
        {
            "type": "os",
            "key": "󰣇 os",
            "keyColor": "{{colors.primary.default.hex}}"
        },
        {
            "type": "kernel",
            "key": "󰘚 kr",
            "keyColor": "{{colors.primary.default.hex}}"
        },
        {
            "type": "packages",
            "key": "󰏖 pk",
            "keyColor": "{{colors.primary.default.hex}}"
        },
        {
            "type": "shell",
            "key": "󰆍 sh",
            "keyColor": "{{colors.primary.default.hex}}"
        },
        "break",
        {
            "type": "wm",
            "key": "󰖲 wm",
            "keyColor": "{{colors.secondary.default.hex}}"
        },
        {
            "type": "terminal",
            "key": "󰗚 tm",
            "keyColor": "{{colors.secondary.default.hex}}"
        },
        {
            "type": "terminalfont",
            "key": "󰛖 ft",
            "keyColor": "{{colors.secondary.default.hex}}"
        },
        "break",
        {
            "type": "host",
            "key": "󰌢 hw",
            "keyColor": "{{colors.tertiary.default.hex}}"
        },
        {
            "type": "cpu",
            "key": "󰻠 cp",
            "keyColor": "{{colors.tertiary.default.hex}}"
        },
        {
            "type": "gpu",
            "key": "󰻑 gp",
            "format": "{2}",
            "keyColor": "{{colors.tertiary.default.hex}}"
        },
        {
            "type": "memory",
            "key": "󰾆 mm",
            "keyColor": "{{colors.tertiary.default.hex}}"
        },
        {
            "type": "display",
            "key": "󰍹 dp",
            "keyColor": "{{colors.tertiary.default.hex}}",
            "compactType": "original-with-refresh-rate"
        },
        {
            "type": "uptime",
            "key": "󰅐 up",
            "keyColor": "{{colors.tertiary.default.hex}}"
        },
        "break",
        {
            "type": "colors",
            "paddingLeft": 4,
            "symbol": "circle"
        },
        "break"
    ]
}
