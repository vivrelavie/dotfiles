# OS
.DS_Store

# Local agent/session artifacts
local-artifacts/
plans/
.obsidian/

# DMS generated files - recreated from wallpaper/theme state
dot_config/**/current-theme.conf
dot_config/DankMaterialShell/.firstlaunch
dot_config/DankMaterialShell/.changelog-*
dot_config/DankMaterialShell/firefox.css
dot_config/DankMaterialShell/zen.css
dot_config/kitty/dank-tabs.conf
dot_config/kitty/dank-theme.conf

# Matugen generated outputs - recreated on wallpaper/theme state
dot_config/fastfetch/config.jsonc
dot_config/starship/starship.toml

# Niri - DMS backups and generated splits
dot_config/niri/config.kdl.backup*
dot_config/niri/config.kdl.dmsbackup*
dot_config/niri/dms/

# Fish generated state
dot_config/private_fish/fish_variables

# DMS plugins repository and install symlinks
dot_config/DankMaterialShell/plugins/*
!dot_config/DankMaterialShell/plugins/*.meta
dot_config/DankMaterialShell/plugins/.repos/
