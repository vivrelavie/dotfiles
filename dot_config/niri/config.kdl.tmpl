{{- $desktop_shell := get . "desktop_shell" | default "dms" -}}
// Managed by chezmoi. Edit dot_config/niri/config.kdl.tmpl, then run chezmoi apply.

environment {
    XDG_CURRENT_DESKTOP "niri"
    QT_QPA_PLATFORM "wayland"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    QT_QPA_PLATFORMTHEME "gtk3"
    QT_QPA_PLATFORMTHEME_QT6 "gtk3"
    DISPLAY ""
}

input {
    keyboard {
        xkb {}
        numlock
    }

    touchpad {
        tap
        natural-scroll
    }

    focus-follows-mouse max-scroll-amount="0%"
}

layout {
    gaps 14
    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        width 2
    }

    border {
        off
    }

    shadow {
        on
        softness 30
        spread 3
        offset x=0 y=5
        color "#0007"
    }
}

// --- Desktop shell startup ---
{{ if eq $desktop_shell "noctalia-v4" }}
spawn-at-startup "qs" "-c" "noctalia-shell"
{{ else if eq $desktop_shell "noctalia-v5" }}
spawn-at-startup "noctalia"
{{ end }}

hotkey-overlay {
    skip-at-startup
}

prefer-no-csd
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

{{ if eq $desktop_shell "dms" }}
// --- DMS only: wallpaper backdrop ---
layer-rule {
    match namespace="dms:blurwallpaper"
    place-within-backdrop true
}
{{ else if or (eq $desktop_shell "noctalia-v4") (eq $desktop_shell "noctalia-v5") }}
// --- Noctalia only: overview backdrop ---
debug {
    honor-xdg-activation-with-invalid-serial
}

layer-rule {
    match namespace="^noctalia-overview*"
    place-within-backdrop true
}
{{ end }}

// --- Shared window rules ---
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

window-rule {
    match is-active=false
    opacity 0.9
}

window-rule {
    match app-id="vesktop"
    draw-border-with-background false
}

window-rule {
    match app-id="kitty"
    draw-border-with-background false
}

window-rule {
    match app-id=r#"^org\.gnome\."#
    draw-border-with-background false
}

window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

{{ if eq $desktop_shell "dms" }}
// --- DMS only: shell windows ---
window-rule {
    match app-id=r#"org.quickshell$"#
    open-floating true
}
{{ else if eq $desktop_shell "noctalia-v5" }}
// --- Noctalia v5 only: settings window ---
window-rule {
    match app-id="dev.noctalia.Noctalia.Settings"
    open-floating true
}
{{ end }}

{{ if eq $desktop_shell "dms" }}
// --- DMS only: generated binds loaded before repo-owned binds ---
include "dms/binds.kdl"
{{ end }}

binds {
{{ if eq $desktop_shell "dms" }}
    // --- DMS only: shell controls ---
    Mod+Shift+Slash { spawn "dms" "ipc" "call" "keybinds" "toggle" "niri"; }
    Mod+Space hotkey-overlay-title="Application Launcher" {
        spawn "dms" "ipc" "call" "spotlight" "toggle";
    }
    Mod+V hotkey-overlay-title="Clipboard Manager" {
        spawn "dms" "ipc" "call" "clipboard" "toggle";
    }
    Mod+T hotkey-overlay-title="Task Manager" {
        spawn "dms" "ipc" "call" "processlist" "focusOrToggle";
    }
    Mod+Shift+S hotkey-overlay-title="Settings" {
        spawn "dms" "ipc" "call" "settings" "focusOrToggle";
    }
    Mod+N hotkey-overlay-title="Notification Center" {
        spawn "dms" "ipc" "call" "notifications" "toggle";
    }
    Mod+Y hotkey-overlay-title="Browse Wallpapers" {
        spawn "dms" "ipc" "call" "dankdash" "wallpaper";
    }
    Mod+Shift+P hotkey-overlay-title="Power Menu" {
        spawn "dms" "ipc" "call" "powermenu" "toggle";
    }
    Mod+Shift+C hotkey-overlay-title="Control Center" {
        spawn "dms" "ipc" "call" "control-center" "toggle";
    }
    Mod+Shift+N hotkey-overlay-title="Notepad" {
        spawn "dms" "ipc" "call" "notepad" "open";
    }
    Mod+Shift+D hotkey-overlay-title="Dashboard" {
        spawn "dms" "ipc" "call" "dash" "toggle" "";
    }
    Mod+Alt+L hotkey-overlay-title="Lock Screen" {
        spawn "dms" "ipc" "call" "lock" "lock";
    }
{{ else if eq $desktop_shell "noctalia-v4" }}
    // --- Noctalia v4 only: shell controls ---
    Mod+Shift+Slash { show-hotkey-overlay; }
    Mod+Space hotkey-overlay-title="Application Launcher" {
        spawn-sh "qs -c noctalia-shell ipc call launcher toggle";
    }
    Mod+V hotkey-overlay-title="Clipboard Manager" {
        spawn-sh "qs -c noctalia-shell ipc call launcher clipboard";
    }
    Mod+T hotkey-overlay-title="System Monitor" {
        spawn-sh "qs -c noctalia-shell ipc call systemMonitor toggle";
    }
    Mod+Shift+S hotkey-overlay-title="Settings" {
        spawn-sh "qs -c noctalia-shell ipc call settings toggle";
    }
    Mod+N hotkey-overlay-title="Notification Center" {
        spawn-sh "qs -c noctalia-shell ipc call notifications toggleHistory";
    }
    Mod+Y hotkey-overlay-title="Browse Wallpapers" {
        spawn-sh "qs -c noctalia-shell ipc call wallpaper toggle";
    }
    Mod+Shift+P hotkey-overlay-title="Power Menu" {
        spawn-sh "qs -c noctalia-shell ipc call sessionMenu toggle";
    }
    Mod+Shift+C hotkey-overlay-title="Control Center" {
        spawn-sh "qs -c noctalia-shell ipc call controlCenter toggle";
    }
    Mod+Alt+L hotkey-overlay-title="Lock Screen" {
        spawn-sh "qs -c noctalia-shell ipc call lockScreen lock";
    }
{{ else if eq $desktop_shell "noctalia-v5" }}
    // --- Noctalia v5 only: shell controls ---
    Mod+Shift+Slash { show-hotkey-overlay; }
    Mod+Space hotkey-overlay-title="Application Launcher" {
        spawn-sh "noctalia msg panel-toggle launcher";
    }
    Mod+V hotkey-overlay-title="Clipboard Manager" {
        spawn-sh "noctalia msg panel-toggle clipboard";
    }
    Mod+Shift+S hotkey-overlay-title="Settings" {
        spawn-sh "noctalia msg settings-toggle";
    }
    Mod+Y hotkey-overlay-title="Browse Wallpapers" {
        spawn-sh "noctalia msg panel-toggle wallpaper";
    }
    Mod+Shift+P hotkey-overlay-title="Power Menu" {
        spawn-sh "noctalia msg panel-toggle session";
    }
    Mod+Shift+C hotkey-overlay-title="Control Center" {
        spawn-sh "noctalia msg panel-toggle control-center";
    }
    Mod+Alt+L hotkey-overlay-title="Lock Screen" {
        spawn-sh "noctalia msg session lock";
    }
{{ else }}
    // --- No desktop shell ---
    Mod+Shift+Slash { show-hotkey-overlay; }
{{ end }}

    // --- Applications ---
    Mod+Return hotkey-overlay-title="Open kitty terminal" { spawn "kitty"; }
    Mod+D repeat=false hotkey-overlay-title="Open Discord" { spawn "vesktop"; }
    Mod+S repeat=false hotkey-overlay-title="Open Spotify" { spawn "spotify"; }
    Mod+B repeat=false hotkey-overlay-title="Open Zen" { spawn "zen-browser"; }
    Mod+Shift+O repeat=false hotkey-overlay-title="Open Obsidian" { spawn "obsidian"; }
    Mod+E repeat=false hotkey-overlay-title="Open Dolphin" { spawn "dolphin"; }
    Mod+Ctrl+C repeat=false hotkey-overlay-title="Open VSCodium" { spawn "vscodium"; }

    // --- Media ---
    XF86AudioPlay allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioStop allow-when-locked=true { spawn-sh "playerctl stop"; }
    XF86AudioPrev allow-when-locked=true { spawn-sh "playerctl previous"; }
    XF86AudioNext allow-when-locked=true { spawn-sh "playerctl next"; }

{{ if eq $desktop_shell "dms" }}
    // --- DMS only: audio and brightness ---
    XF86AudioRaiseVolume allow-when-locked=true cooldown-ms=150 {
        spawn "dms" "ipc" "call" "audio" "increment" "5";
    }
    XF86AudioLowerVolume allow-when-locked=true cooldown-ms=150 {
        spawn "dms" "ipc" "call" "audio" "decrement" "5";
    }
    XF86AudioMute allow-when-locked=true cooldown-ms=150 {
        spawn "dms" "ipc" "call" "audio" "mute";
    }
    XF86MonBrightnessUp allow-when-locked=true {
        spawn "dms" "ipc" "call" "brightness" "increment" "5" "";
    }
    XF86MonBrightnessDown allow-when-locked=true {
        spawn "dms" "ipc" "call" "brightness" "decrement" "5" "";
    }
{{ else if eq $desktop_shell "noctalia-v4" }}
    // --- Noctalia v4 only: audio and brightness ---
    XF86AudioRaiseVolume allow-when-locked=true cooldown-ms=150 {
        spawn-sh "qs -c noctalia-shell ipc call volume increase";
    }
    XF86AudioLowerVolume allow-when-locked=true cooldown-ms=150 {
        spawn-sh "qs -c noctalia-shell ipc call volume decrease";
    }
    XF86AudioMute allow-when-locked=true cooldown-ms=150 {
        spawn-sh "qs -c noctalia-shell ipc call volume muteOutput";
    }
    XF86MonBrightnessUp allow-when-locked=true {
        spawn-sh "qs -c noctalia-shell ipc call brightness increase";
    }
    XF86MonBrightnessDown allow-when-locked=true {
        spawn-sh "qs -c noctalia-shell ipc call brightness decrease";
    }
{{ else if eq $desktop_shell "noctalia-v5" }}
    // --- Noctalia v5 only: audio and brightness ---
    XF86AudioRaiseVolume allow-when-locked=true cooldown-ms=150 {
        spawn-sh "noctalia msg volume-up";
    }
    XF86AudioLowerVolume allow-when-locked=true cooldown-ms=150 {
        spawn-sh "noctalia msg volume-down";
    }
    XF86AudioMute allow-when-locked=true cooldown-ms=150 {
        spawn-sh "noctalia msg volume-mute";
    }
    XF86MonBrightnessUp allow-when-locked=true {
        spawn-sh "noctalia msg brightness-up";
    }
    XF86MonBrightnessDown allow-when-locked=true {
        spawn-sh "noctalia msg brightness-down";
    }
{{ else }}
    // --- Generic audio and brightness ---
    XF86AudioRaiseVolume allow-when-locked=true cooldown-ms=150 {
        spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ -l 1.0";
    }
    XF86AudioLowerVolume allow-when-locked=true cooldown-ms=150 {
        spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-";
    }
    XF86AudioMute allow-when-locked=true cooldown-ms=150 {
        spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle";
    }
    XF86MonBrightnessUp allow-when-locked=true {
        spawn "brightnessctl" "--class=backlight" "set" "+5%";
    }
    XF86MonBrightnessDown allow-when-locked=true {
        spawn "brightnessctl" "--class=backlight" "set" "5%-";
    }
{{ end }}

    // --- Window and workspace navigation ---
    Mod+O repeat=false { toggle-overview; }
    Mod+Q repeat=false { close-window; }

    Mod+Left { focus-column-left; }
    Mod+Down { focus-window-down; }
    Mod+Up { focus-window-up; }
    Mod+Right { focus-column-right; }

    Mod+Ctrl+Left { move-column-left; }
    Mod+Ctrl+Down { move-window-down; }
    Mod+Ctrl+Up { move-window-up; }
    Mod+Ctrl+Right { move-column-right; }

    Mod+U { focus-workspace-down; }
    Mod+I { focus-workspace-up; }
    Mod+Ctrl+U { move-column-to-workspace-down; }
    Mod+Ctrl+I { move-column-to-workspace-up; }
    Mod+Shift+U { move-workspace-down; }
    Mod+Shift+I { move-workspace-up; }

    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp cooldown-ms=150 { move-column-to-workspace-up; }
    Mod+Shift+WheelScrollDown { focus-column-right; }
    Mod+Shift+WheelScrollUp { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp { move-column-left; }

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }

    Mod+BracketLeft { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    Mod+Comma { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }

    Mod+R { switch-preset-column-width; }
    Mod+Shift+R { switch-preset-column-width-back; }
    Mod+Ctrl+Shift+R { switch-preset-window-height; }
    Mod+Ctrl+R { reset-window-height; }

    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }
    Mod+M { maximize-window-to-edges; }
    Mod+Ctrl+F { expand-column-to-available-width; }
    Mod+C { center-column; }

    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    Mod+W { toggle-window-floating; }
    Mod+Shift+W { switch-focus-between-floating-and-tiling; }

    // --- Session and screenshots ---
    Print { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
    Mod+Shift+E { quit; }
    Ctrl+Alt+Delete { quit; }
}

{{ if eq $desktop_shell "dms" }}
// --- DMS only: generated Niri fragments ---
include "~/.cache/DankMaterialShell/niri-focus.kdl"
include "dms/cursor.kdl"
include "dms/windowrules.kdl"
include "dms/wpblur.kdl"
{{ end }}
