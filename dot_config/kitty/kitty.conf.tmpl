{{- $desktop_shell := get . "desktop_shell" | default "dms" -}}
# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  kitty.conf                                                                  │
# └──────────────────────────────────────────────────────────────────────────────┘

# ── Colors ───────────────────────────────────────────────────────────────────
{{- if eq $desktop_shell "dms" }}
# Generated by DMS into ~/.config/kitty. Regenerate before first launch on a fresh setup.
include dank-tabs.conf
include dank-theme.conf
{{- else }}
# Shell-specific generated theme includes are skipped for non-DMS profiles.
{{- end }}

# ── Font ─────────────────────────────────────────────────────────────────────
font_family      JetBrains Mono Nerd Font
font_size 11.0
bold_font        11.0
italic_font      auto
bold_italic_font auto
modify_font cell_height 95%


# ── Glass ────────────────────────────────────────────────────────────────────
# background_opacity 0.9
# background_blur    64

# ── Cursor ───────────────────────────────────────────────────────────────────
cursor_shape beam
cursor_trail 1
cursor_trail_decay 0.15 0.4

# ── Window ───────────────────────────────────────────────────────────────────
window_padding_width 12 16
placement_strategy center
hide_window_decorations yes
confirm_os_window_close 0
shell /usr/bin/fish

# ── Scrollback ───────────────────────────────────────────────────────────────
scrollback_lines      5000
wheel_scroll_min_lines 1

# ── Copy ─────────────────────────────────────────────────────────────────────
map ctrl+c    copy_or_interrupt

# ── Search ───────────────────────────────────────────────────────────────────
map ctrl+f   launch --location=hsplit --allow-remote-control kitty +kitten search.py @active-kitty-window-id
map kitty_mod+f   launch --location=hsplit --allow-remote-control kitty +kitten search.py @active-kitty-window-id

# ── Scroll and Zoom ──────────────────────────────────────────────────────────
map ctrl+plus  change_font_size all +1
map ctrl+equal  change_font_size all +1
map ctrl+kp_add  change_font_size all +1
map ctrl+minus       change_font_size all -1
map ctrl+underscore       change_font_size all -1
map ctrl+kp_subtract       change_font_size all -1
map ctrl+0 change_font_size all 0
map ctrl+kp_0 change_font_size all 0
